# A.R.I.A. Backend Configuration
# Copy to .env and adjust as needed.

# Server
ARIA_HOST=0.0.0.0
ARIA_PORT=8000

# Whisper ASR
ARIA_WHISPER_MODEL=small
ARIA_WHISPER_COMPUTE_TYPE=int8
ARIA_WHISPER_DEVICE=cuda
ARIA_WHISPER_CPU_THREADS=4

# LLM (Ollama)
ARIA_LLM_MODEL=phi3:mini
ARIA_LLM_TEMPERATURE=0.1
ARIA_LLM_NUM_CTX=4096

# ChromaDB
ARIA_CHROMA_PATH=./chroma_db

# VRAM budget (bytes) — default 4 GiB for GTX 1650
ARIA_VRAM_BUDGET=4294967296
